# Copy this to .env and fill in your values
# Resolution order: Env Var > YAML manifest > hardcoded default

# ── Google AI ─────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── Run mode ──────────────────────────────────────────────────────────────────
# ui       → adk web (browser dashboard)
# terminal → interactive REPL
RUN_MODE=ui

# ── Orchestrator mode ─────────────────────────────────────────────────────────
# false (default) → single agent loaded from MANIFEST_PATH
# true            → orchestrator + specialist sub-agents (ignores MANIFEST_PATH)
ORCHESTRATOR_MODE=false

# ── Agent model (overrides manifest model.base_model_id) ─────────────────────
# AGENT_MODEL_NAME=gemini-2.5-flash

# ── Manifest path (single agent mode only — ignored when ORCHESTRATOR_MODE=true) ─
# MANIFEST_PATH=orchestrator/manifest/incident_agent_manifest.yaml

# ── Policy overrides (override manifest policy section) ──────────────────────
# CONFIDENCE_THRESHOLD=0.7
# ALLOWED_PROBLEM_TYPES=arithmetic,algebra,word_problems
# DENIED_PROBLEM_TYPES=calculus,differential_equations,abstract_algebra

# ── Rate limit overrides (override manifest policy.rate_limits section) ───────
# RATE_LIMIT_RPM=30
# MAX_CONCURRENT_SESSIONS=5

# ── Lifecycle overrides (override manifest deployment.lifecycle section) ──────
# MAX_TURNS=20
# SESSION_TIMEOUT=300

# ── BigQuery (incident agent) ────────────────────────────────────────────────
# Required when running the incident analysis agent.
# Authenticated via gcloud ADC or GOOGLE_APPLICATION_CREDENTIALS.
# BQ_PROJECT=gsk-corp-ai-tech-ops-dev
# BQ_DATASET=snow
# BQ_RAW_TABLE=raw_incidents
# BQ_RESULT_TABLE=analysis_result

# ── Guardrail settings (incident agent) ──────────────────────────────────────
# ENABLE_LLM_POLICY_GUARDRAIL=1
# GUARDRAIL_MODEL=gemini-2.5-flash
# GUARDRAIL_FAIL_CLOSED=1

# ── Web Research Agent (Firecrawl MCP) ───────────────────────────────────────
# Required when running the web research agent.
# Get your API key at: https://firecrawl.dev
# Also requires Node.js installed (npx is used to run the MCP server).
# FIRECRAWL_API_KEY=your_firecrawl_api_key_here
